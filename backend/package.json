{
  "name": "minilib-backend",
  "version": "1.0.0",
  "description": "API REST Minilib - Node.ts / Express",
  "author": "Nif-dev",
  "type": "module",
  "private": true,
  "main": "src/app.ts",
  "scripts": {
    "start": "tsx --env-files=.env src/app.ts",
    "start:prod": "tsx --env-files=.env.dev dist/app.ts",
    "dev": "tsx watch --env-file=.env.dev src/app.ts",
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "echo \"Error: no test specified...YET !\" && exit 1"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "tsx": "^4.21.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0"
  }
}
