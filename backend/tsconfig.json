//% backend/tsconfig.json
{
"compilerOptions": {
"target": "ES2022",
"module": "NodeNext",
"moduleResolution": "NodeNext",
"outDir": "./dist",
"rootDir": "./src",
"strict": true,
"esModuleInterop": true,
"skipLibCheck": true,
// permet de compiler les imports relatifs - passe les .ts en .js sur imports
"rewriteRelativeImportExtensions": true,
// noEmit vérifie les types sans générer de fichiers
// noEmit: true,
// "allowImportingTsExtensions": true,
//! attention pas de building ! ./dist/ est vide si noEmit = true
// On garde Node 24 natif pour exécuter -- pas de compilation réelle
// "checkJs": true,
"allowJs": true,
"types": ["node", "@types/express"],
},
"include": ["src/**/*"],
"exclude": ["node_modules", "dist"]
}